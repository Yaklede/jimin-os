JIMIN_ENVIRONMENT=staging
JIMIN_COMPOSE_PROJECT=jimin-os-staging
JIMIN_OS_HOSTNAME=jimin-os-staging.private.example
JIMIN_GATEWAY_BIND_ADDRESS=0.0.0.0
JIMIN_GATEWAY_HOST_PORT=443
JIMIN_GATEWAY_CONTAINER_PORT=8443
JIMIN_TLS_MODE=internal
JIMIN_SECRETS_DIR=./deploy/secrets/staging

JIMIN_API_BIND_ADDR=0.0.0.0:8080
JIMIN_API_PROBE_ADDR=127.0.0.1:8080
JIMIN_DATABASE_MAX_CONNECTIONS=5
JIMIN_DATABASE_ACQUIRE_TIMEOUT_MS=2000
JIMIN_TRUSTED_NETWORK=1
JIMIN_AGENT_DATABASE_MAX_CONNECTIONS=2
JIMIN_AGENT_DATABASE_ACQUIRE_TIMEOUT_MS=2000
JIMIN_AGENT_CLAIM_LEASE_SECONDS=30
JIMIN_AGENT_POLL_INTERVAL_MS=500
JIMIN_AGENT_RUNNER_ID=agent-primary
JIMIN_POSTGRES_DB=jimin_os
JIMIN_POSTGRES_USER=jimin_api
JIMIN_AUTH_ISSUER=https://jimin-os-staging.private.example
JIMIN_AUTH_KEY_ID=staging-ed25519-20260710
JIMIN_AUTH_ACCESS_TOKEN_TTL_SECONDS=600
JIMIN_AUTH_SESSION_TTL_SECONDS=2592000
RUST_LOG=info,jimin_api=info,jimin_agent=info

# Staging deploy requires registry digests, not tags. Replace all placeholders.
JIMIN_API_IMAGE=ghcr.io/owner/jimin-os-api@sha256:replace-with-64-hex-digest
JIMIN_AGENT_IMAGE=ghcr.io/owner/jimin-os-agent@sha256:replace-with-64-hex-digest
JIMIN_GATEWAY_IMAGE=ghcr.io/owner/jimin-os-gateway@sha256:replace-with-64-hex-digest
JIMIN_BUILD_SHA=replace-with-full-git-sha

# Optional: set when private DNS is not available on the deployment host.
JIMIN_SMOKE_RESOLVE_IP=
