JIMIN_ENVIRONMENT=local
JIMIN_COMPOSE_PROJECT=jimin-os-local
JIMIN_OS_HOSTNAME=localhost
JIMIN_GATEWAY_BIND_ADDRESS=127.0.0.1
JIMIN_GATEWAY_HOST_PORT=8443
JIMIN_GATEWAY_CONTAINER_PORT=8443
JIMIN_TLS_MODE=internal
JIMIN_SECRETS_DIR=./deploy/secrets/local

JIMIN_API_BIND_ADDR=0.0.0.0:8080
JIMIN_API_PROBE_ADDR=127.0.0.1:8080
JIMIN_DATABASE_MAX_CONNECTIONS=5
JIMIN_DATABASE_ACQUIRE_TIMEOUT_MS=2000
JIMIN_POSTGRES_DB=jimin_os
JIMIN_POSTGRES_USER=jimin_api
JIMIN_AUTH_ISSUER=https://localhost:8443
JIMIN_AUTH_KEY_ID=local-ed25519-20260710
JIMIN_AUTH_ACCESS_TOKEN_TTL_SECONDS=600
JIMIN_AUTH_SESSION_TTL_SECONDS=2592000
JIMIN_GOOGLE_MACOS_CLIENT_ID=local-client.apps.googleusercontent.com
JIMIN_GOOGLE_MACOS_REDIRECT_URI=jimin-os://oauth
RUST_LOG=info,jimin_api=debug,jimin_agent=debug

# Optional: keep empty unless local DNS does not resolve JIMIN_OS_HOSTNAME.
JIMIN_SMOKE_RESOLVE_IP=
