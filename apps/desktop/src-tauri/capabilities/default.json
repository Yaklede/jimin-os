{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Jimin OS main application window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://auth.openai.com/*" },
        { "url": "https://chatgpt.com/*" },
        { "url": "https://accounts.google.com/*" }
      ]
    },
    "voice-recognition:allow-start",
    "voice-recognition:allow-stop",
    "voice-recognition:allow-cancel",
    "local-notifications:allow-permissionStatus",
    "local-notifications:allow-requestPermission",
    "local-notifications:allow-openSettings",
    "local-notifications:allow-schedule",
    "local-notifications:allow-cancel",
    "local-notifications:allow-reconcileScheduled",
    "local-notifications:allow-takePendingNavigation",
    "local-notifications:allow-peekPendingNavigation",
    "local-notifications:allow-ackPendingNavigation",
    "local-notifications:allow-pushToken"
  ]
}
