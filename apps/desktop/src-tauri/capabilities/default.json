{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Jimin OS main application window permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://auth.openai.com/*" },
        { "url": "https://chatgpt.com/*" }
      ]
    }
  ]
}
